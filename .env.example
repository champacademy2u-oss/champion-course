PORT=4175
HOST=127.0.0.1

# Meta / Facebook App
META_GRAPH_VERSION=v21.0
META_VERIFY_TOKEN=change-this-random-token
META_APP_SECRET=your-facebook-app-secret
META_PAGE_ACCESS_TOKEN=your-long-lived-page-access-token
# Optional when using one page token:
# META_PAGE_ID=your-facebook-page-id
# Optional for multiple Facebook Pages:
# META_PAGE_ACCESS_TOKENS={"1234567890":"page-token-1","9876543210":"page-token-2"}

# Google Drive
GOOGLE_DRIVE_FOLDER_ID=your-google-drive-folder-id
GOOGLE_DRIVE_CSV_NAME=facebook-leads.csv

# Choose one service account option:
GOOGLE_SERVICE_ACCOUNT_FILE=./google-service-account.json
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
